// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Better Auth tables

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts     Account[]
  sessions     Session[]
  transmittals Transmittal[]

  @@map("user")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

/////////////////////////////////----------------------------------------------------
model Transmittal {
  id     String @id @default(cuid())
  userId String
  notes  String

  // Transmittal Methods
  handDelivery   Boolean
  pickUp         Boolean
  courier        Boolean
  registeredMail Boolean

  recipients Recipient[]
  agency     Agency?

  items TransmittalItem[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectName         String
  projectNumber       String?
  engagementRefNumber String?
  projectPurpose      String?

  //LAST DATA in the Document
  project     Json
  sender      Json
  receivedBy  Json
  footerNotes Json

  preparedBy     String
  preparedByRole String
  notedBy        String
  notedByRole    String
  timeReleased   String

  @@index([userId])
  @@map("transmittal")
}

model Recipient {
  id                           String  @id @default(cuid())
  transmittalId                String
  recipientName                String
  recipientOrganization        String?
  recipientAttention           String?
  recipientFullAddress         String?
  recipientAgencyContactNumber String?
  recipientAgencyEmail         String?

  transmittal Transmittal @relation(fields: [transmittalId], references: [id], onDelete: Cascade)

  @@index([transmittalId])
  @@map("recipient")
}

model TransmittalItem {
  id             String  @id @default(cuid())
  transmittalId  String
  qty            String
  noOfItems      String
  documentNumber String
  description    String
  remarks        String
  fileType       String?
  fileSource     String?

  transmittal Transmittal @relation(fields: [transmittalId], references: [id], onDelete: Cascade)

  @@index([transmittalId])
  @@map("transmittal_item")
}

// used for the agency that will issue the transmittal (BRAND TAB)
model Agency {
  id              String  @id @default(cuid())
  transmittalId   String  @unique
  name            String
  website         String?
  telephoneNumber String?
  contactNumber   String?
  email           String?

  transmittal Transmittal @relation(fields: [transmittalId], references: [id], onDelete: Cascade)

  @@map("agency")
}
